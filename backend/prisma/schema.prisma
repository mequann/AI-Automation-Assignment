// Prisma schema for AI Meeting Preparation Assistant

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Meeting {
  id           Int      @id @default(autoincrement())
  title        String
  time         DateTime
  participants String[]
  agenda       String[]
  actionItems  String[]
  emailDraft   String
  createdAt    DateTime @default(now())
}
